<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".views.TextViewExample">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="First Text View"
        android:textSize="20sp"
        android:textColor="@color/ligth_blue"
        android:textAllCaps="false"
        android:textFontWeight="700"
        android:fontFamily="@font/yuyu_regular"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:autoLink="web"
        android:textStyle="bold"
        android:text="Visit : https://www.youtube.com"
        android:fontFamily="sans-serif-condensed"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="italic"
        android:textSize="25sp"
        android:autoLink="phone"
        android:text="Contact : +918810365603"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:autoLink="email"
        android:textStyle="italic"
        android:textSize="30sp"
        android:text="support@gmail.com"
        />


</LinearLayout>